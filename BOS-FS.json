{
  "name": "BOS-FS",
  "version": "0.0.6",
  "tagline": "Build · Optimize · Submit",
  "author": "HOS(安全风信子)",
  "category": "submission_engineering",
  "license": "MIT",
  "skills": [
    {"id": "goal_refiner", "name": "Goal Refiner", "file": "skills/01_goal_refiner.md", "output": "{persona,problem,solution,outcome}", "trigger": "描述项目时"},
    {"id": "reviewer_simulator", "name": "Reviewer Simulator", "file": "skills/02_reviewer_simulator.md", "output": "{pass_probability,rejection_reasons,suggestions}", "trigger": "预审时"},
    {"id": "readme_refactor", "name": "README Refactor", "file": "skills/03_readme_refactor.md", "output": "重构后README", "trigger": "优化文档时"},
    {"id": "outcome_mapper", "name": "Outcome Mapper", "file": "skills/04_outcome_mapper.md", "output": "{feature,capability,outcome}", "trigger": "价值转换时"},
    {"id": "submission_builder", "name": "Submission Builder", "file": "skills/05_submission_builder.md", "output": "submission_bundle/", "trigger": "准备提交时"},
    {"id": "reject_analyzer", "name": "Reject Analyzer", "file": "skills/06_reject_analyzer.md", "output": "{real_issue,fixable_items,resubmit_suggestion}", "trigger": "项目被拒时"},
    {"id": "pipeline", "name": "Pipeline Orchestrator", "file": "skills/pipeline.md"}
  ],
  "pipeline": {
    "stages": [
      {"name": "Understand", "skill": "goal_refiner"},
      {"name": "Map", "skill": "outcome_mapper"},
      {"name": "Refactor", "skill": "readme_refactor"},
      {"name": "Review", "skill": "reviewer_simulator"},
      {"name": "Build", "skill": "submission_builder"},
      {"name": "Analyze", "skill": "reject_analyzer"}
    ],
    "flow": "Repo → Understand → Optimize → Review → Package → Submit"
  },
  "principles": {
    "dont": ["伪造成果", "伪造用户", "伪造数据", "夸大能力", "规避规则"],
    "do": ["明确目标", "补齐交付", "重构描述", "对齐评审语言"]
  },
  "changelog": {
    "0.0.6": "集成指南合并、评分文件清理、Skill目录精简、模板格式增强",
    "0.0.5": "Skill文件压缩、Knowledge库合并(竞品分析+差异化)、评分标准统一、模板精简",
    "0.0.4": "README高密度化、集成指南合并、元数据精简",
    "0.0.3": "Skill Token优化(~55%压缩)、.trae/目录去重、公共上下文提取",
    "0.0.2": "生产级Skill、pipeline编排器、多平台集成",
    "0.0.1": "初始版本：六大Skill+基础Runtime+知识库"
  }
}
